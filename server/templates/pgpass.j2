{# Rendered into /etc/credstore/pgpass-<server>, exposed by systemd LoadCredential= as PGPASSFILE.
   Format: hostname:port:database:username:password — read natively by libpq. #}
{% for name, db in (postgresql | default({})).items() -%}
{{ db.host }}:{{ db.port | default(5432) }}:{{ db.dbname }}:{{ db.user }}:{{ postgresql_secrets[name] }}
{% endfor %}
