#!/bin/bash
set -uo pipefail

MOUNT_TARGET="$1"
LOG_DIR="{{ backup.log_dir }}"
TMP_LOG_DIR="/tmp/backup"
LOG="$TMP_LOG_DIR/rsync.log"
SERVER="{{ backup.server_name }}"

HAS_ERRORS=false

log() {
  echo "$(date '+%Y-%m-%d--%H-%M-%S') $1" >> "$LOG"
}

backup_task() {
  local name="$1"
  local source="$2"
  local target="$3"
  shift 3
  local excludes=()
  local e
  for e in "$@"; do
    excludes+=(--exclude="$e")
  done
  local timestamp
  timestamp=$(date '+%Y-%m-%d--%H-%M-%S')

  local task_log="$TMP_LOG_DIR/$name-$timestamp.log"
  local err_log="$TMP_LOG_DIR/$name-error-$timestamp.log"
  log "[rsync] $name started..."
  mkdir -p "$(dirname "$target")"
  if rsync -av --delete "${excludes[@]}" \
    --info=NAME,STATS2,FLIST0 \
    --log-file="$task_log" \
    --log-file-format="[%t] %i %f" \
    "$source" "$target" 2>"$err_log"; then
    log "[rsync] $name completed successfully"
    rm -f "$err_log"
  else
    local rc=$?
    HAS_ERRORS=true
    if [ -s "$err_log" ]; then
      local err_count
      err_count=$(wc -l < "$err_log")
      echo "TOTAL ERRORS: $err_count" >> "$err_log"
      log "[rsync] $name FAILED with exit code $rc, $err_count error lines (see $err_log)"
      cp "$err_log" "$LOG_DIR/"
    else
      rm -f "$err_log"
      log "[rsync] $name FAILED with exit code $rc (no stderr output)"
    fi
  fi
  cp "$task_log" "$LOG_DIR/"
}

cleanup() {
  local exit_code=$?
  cp "$LOG" "$LOG_DIR/" 2>/dev/null || true
  if [ "$HAS_ERRORS" = true ] && [ "$exit_code" -eq 0 ]; then
    exit 1
  fi
  exit "$exit_code"
}
trap cleanup EXIT

prepare() {
  mkdir -p "$TMP_LOG_DIR" "$LOG_DIR"
  if ! mountpoint -q "$MOUNT_TARGET"; then
    log "ERROR: $MOUNT_TARGET is not a mountpoint"
    exit 1
  fi
  log "Started $SERVER files backup"
}

prepare

{% for item_name, item_data in backup.tasks.items() %}
backup_task \
  "{{ item_name }}" \
  "{{ item_data.source }}" \
  "{{ item_data.target }}"{% for ex in item_data.excludes | default([]) %} \
  "{{ ex }}"{% endfor %}

{% endfor %}

log "Ended $SERVER files backup"
