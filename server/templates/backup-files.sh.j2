#!/bin/bash
set -uo pipefail

DEVICE="$1"
MOUNT_TARGET="{{ backup.target_mount }}"
LOG_DIR="{{ backup.log_dir }}"
TMP_LOG_DIR="/tmp/backup"
LOG="$TMP_LOG_DIR/rsync.log"
SERVER="{{ backup.server_name }}"
HA_BASE="http://{{ homeassistant_kvm.ip }}:8123/api/webhook"
MOUNTED_BY_SCRIPT=false

log() {
  echo "$(date '+%Y-%m-%d--%H-%M-%S') $1" >> "$LOG"
}

backup_task() {
  local name="$1"
  local source="$2"
  local target="$3"
  shift 3
  local excludes=()
  local e
  for e in "$@"; do
    excludes+=(--exclude="$e")
  done
  local timestamp
  timestamp=$(date '+%Y-%m-%d--%H-%M-%S')

  local task_log="$TMP_LOG_DIR/$name-$timestamp.log"
  local err_log="$TMP_LOG_DIR/$name-error-$timestamp.log"
  log "[rsync] $name started..."
  mkdir -p "$(dirname "$target")"
  if rsync -av --delete "${excludes[@]}" \
    --info=NAME,STATS2,FLIST0 \
    --log-file="$task_log" \
    --log-file-format="[%t] %i %f" \
    "$source" "$target" 2>"$err_log"; then
    log "[rsync] $name completed successfully"
    rm -f "$err_log"
  else
    local rc=$?
    if [ -s "$err_log" ]; then
      local err_count
      err_count=$(wc -l < "$err_log")
      echo "TOTAL ERRORS: $err_count" >> "$err_log"
      log "[rsync] $name FAILED with exit code $rc, $err_count error lines (see $err_log)"
      cp "$err_log" "$LOG_DIR/"
    else
      rm -f "$err_log"
      log "[rsync] $name FAILED with exit code $rc (no stderr output)"
    fi
  fi
  cp "$task_log" "$LOG_DIR/"
}

cleanup() {
  local exit_code=$?
  sync
  local has_errors=false
  if compgen -G "$TMP_LOG_DIR/*-error-*.log" >/dev/null; then
    has_errors=true
  fi
  if [ "$MOUNTED_BY_SCRIPT" = true ]; then
    log "Unmounting $MOUNT_TARGET ..."
    cp "$LOG" "$LOG_DIR/" 2>/dev/null || true
    sync
    umount "$MOUNT_TARGET" 2>/dev/null || log "Warning: umount failed (device may already be unmounted)"
  fi
  if [ $exit_code -eq 0 ] && [ "$has_errors" = false ]; then
    curl -s -X PUT "$HA_BASE/{{ backup.webhook.completed.id }}"
  else
    log "Backup failed (exit_code=$exit_code, has_errors=$has_errors)"
    curl -s -X PUT "$HA_BASE/{{ backup.webhook.has_error.id }}" || true
  fi
}
trap cleanup EXIT

prepare() {
  mkdir -p "$TMP_LOG_DIR"
  log "Preparing $SERVER before backup"

  mkdir -p "$MOUNT_TARGET"

  curl -s -X PUT "$HA_BASE/{{ backup.webhook.started.id }}"

  if ! mount | grep -q "$DEVICE "; then
    mount "$DEVICE" "$MOUNT_TARGET" || {
      log "Error mounting $DEVICE to $MOUNT_TARGET"
      exit 1
    }
    MOUNTED_BY_SCRIPT=true
  else
    log "Device $DEVICE already mounted, continuing"
  fi

  mkdir -p "$LOG_DIR"

  log "Started $SERVER backup"
}

prepare

{% for item_name, item_data in backup.tasks.items() %}
backup_task \
  "{{ item_name }}" \
  "{{ item_data.source }}" \
  "{{ item_data.target }}"{% for ex in item_data.excludes | default([]) %} \
  "{{ ex }}"{% endfor %}

{% endfor %}

log "Ended $SERVER backup"
