#!/bin/bash
set -uo pipefail

DEVICE="$1"
MOUNT_TARGET="{{ backup.target_mount }}"
LOG_DIR="{{ backup.log_dir }}"
TMP_LOG_DIR="/tmp/backup"
LOG="$TMP_LOG_DIR/server.log"
SERVER="{{ backup.server_name }}"
HA_BASE="http://{{ homeassistant_kvm.ip }}:8123/api/webhook"

MOUNTED_BY_SCRIPT=false
FILES_RC=0
DB_RC=0

log() {
  echo "$(date '+%Y-%m-%d--%H-%M-%S') $1" >> "$LOG"
}

cleanup() {
  local exit_code=$?
  sync
  cp "$LOG" "$LOG_DIR/" 2>/dev/null || true

  if [ "$MOUNTED_BY_SCRIPT" = true ]; then
    log "Unmounting $MOUNT_TARGET ..."
    sync
    umount "$MOUNT_TARGET" 2>/dev/null \
      || log "Warning: umount failed (device may already be unmounted)"
  fi

  if [ "$exit_code" -eq 0 ] && [ "$FILES_RC" -eq 0 ] && [ "$DB_RC" -eq 0 ]; then
    log "Backup completed: files=ok db=ok"
    curl -s -X PUT "$HA_BASE/{{ backup.webhook.completed.id }}" || true
  else
    log "Backup failed (exit_code=$exit_code files_rc=$FILES_RC db_rc=$DB_RC)"
    curl -s -X PUT "$HA_BASE/{{ backup.webhook.has_error.id }}" || true
  fi
}
trap cleanup EXIT

prepare() {
  mkdir -p "$TMP_LOG_DIR"
  log "Preparing $SERVER backup (device=$DEVICE)"

  curl -s -X PUT "$HA_BASE/{{ backup.webhook.started.id }}" || true

  mkdir -p "$MOUNT_TARGET"
  if ! mountpoint -q "$MOUNT_TARGET"; then
    mount "$DEVICE" "$MOUNT_TARGET" || {
      log "Error mounting $DEVICE to $MOUNT_TARGET"
      exit 1
    }
    MOUNTED_BY_SCRIPT=true
  else
    log "$MOUNT_TARGET already mounted, continuing"
  fi

  mkdir -p "$LOG_DIR"
  log "Started $SERVER backup"
}

prepare

log "Dispatching files backup ..."
/opt/scripts/backup-files.sh "$MOUNT_TARGET" || FILES_RC=$?
log "Files backup finished rc=$FILES_RC"

log "Dispatching DB backup ..."
/opt/scripts/backup-db.sh "$MOUNT_TARGET" || DB_RC=$?
log "DB backup finished rc=$DB_RC"

log "Ended $SERVER backup"
